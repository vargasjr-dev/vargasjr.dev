{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}"
  ],
  "project": [
    "app/**/*.{ts,tsx,js,jsx}",
    "!**/*.test.{ts,tsx,js,jsx}",
    "!**/*.spec.{ts,tsx,js,jsx}",
    "!eslint-rules/**/*.js"
  ],
  "ignore": [
    "dist/**",
    "node_modules/**",
    "**/*.test.{ts,tsx,js,jsx}",
    "**/*.spec.{ts,tsx,js,jsx}",
    "eslint-rules/**/*.js",
    "drizzle.config.ts",
    "next.config.ts",
    "tailwind.config.ts",
    "vitest.config.ts"
  ],
  "ignoreBinaries": ["prettier"]
}
